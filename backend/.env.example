# ---- Database ----
DATABASE_URL=postgresql+psycopg://attendance:attendance@localhost:5432/attendance

# ---- Auth ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Bootstrap admin (created on first startup if no admin exists)
BOOTSTRAP_ADMIN_MOBILE=+910000000000
BOOTSTRAP_ADMIN_PASSWORD=admin12345
BOOTSTRAP_ADMIN_NAME=System Admin

# ---- Face recognition (all OPEN-DECISION knobs live here, never hard-coded) ----
# Primary match threshold: cosine similarity above this => same person.
FACE_MATCH_THRESHOLD=0.45
# Detector confidence below which a detection is ignored entirely.
FACE_DET_SCORE_MIN=0.50
# Quality gate (OPEN DECISION #6 - discard tiny/side/blurry faces).
FACE_MIN_PIXELS=40          # min bounding-box width OR height in px
FACE_MAX_YAW_DEG=45         # discard side-profiles beyond this yaw
FACE_BLUR_VAR_MIN=10.0      # variance-of-Laplacian below this => too blurry (low: messaging apps recompress)
# InsightFace model pack + provider.
INSIGHTFACE_MODEL=buffalo_l
INSIGHTFACE_PROVIDERS=CPUExecutionProvider
# Reject group photos whose EXIF capture date is this many days old or more.
MAX_PHOTO_AGE_DAYS=7

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
# OPEN DECISION #5: match the message sender on user id (default) vs stored chat id.
# Kept here + isolated in services/leader_resolver.py so it can be switched in one place.
TELEGRAM_MATCH_FIELD=user_id   # one of: user_id | chat_id
# Group reply style after processing a photo: minimal | silent | private
TELEGRAM_REPLY_MODE=minimal

# ---- Storage ----
# Where pending visitor face crops are written (deleted on review; never the full photo).
VISITOR_CROP_DIR=./var/visitor_crops
# Member face thumbnails (retained with the profile; shown in Visitor Review).
MEMBER_PHOTO_DIR=./var/member_photos

# ---- App ----
CORS_ORIGINS=http://localhost:4200
