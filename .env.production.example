# Copy these into Coolify's "Environment Variables" for the resource.
# Mark the secrets (password, JWT, token) as "secret" in Coolify.

# --- Database ---
POSTGRES_USER=attendance
POSTGRES_PASSWORD=CHANGE_ME_long_random
POSTGRES_DB=attendance

# --- Auth / JWT ---
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_hex_chars
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- First admin (created on first boot) ---
BOOTSTRAP_ADMIN_MOBILE=+9190000XXXXX
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong
BOOTSTRAP_ADMIN_NAME=System Admin

# --- Web origin allowed to call the API (the dashboard domain) ---
CORS_ORIGINS=https://bsg.rmoffice.online

# --- Recognition / policy ---
MAX_PHOTO_AGE_DAYS=7

# --- Telegram (optional here; you can instead set it in the in-app Settings page) ---
TELEGRAM_BOT_TOKEN=
